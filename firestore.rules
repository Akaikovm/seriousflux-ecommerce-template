rules_version = '2';

/**
 * SeriousFlux Firestore Security Rules (GAP-001 / ADR-024).
 *
 * Admin role is read from `customers/{uid}.role` until custom claims (GAP-002).
 * Privileged server paths (webhooks, Admin SSR) use the Admin SDK and bypass rules.
 */
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function customerDoc() {
      return get(/databases/$(database)/documents/customers/$(request.auth.uid)).data;
    }

    function isActiveAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/customers/$(request.auth.uid))
        && customerDoc().role == 'admin'
        && customerDoc().status == 'active';
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function orderCreateValid() {
      let data = request.resource.data;
      return data.keys().hasAll([
          'orderNumber',
          'customerEmail',
          'customerName',
          'customerPhone',
          'status',
          'items',
          'shippingAddress',
          'shippingMethod',
          'payment',
          'totals',
          'currency',
          'createdAt',
          'updatedAt'
        ])
        && data.status == 'pending_payment'
        && data.payment.status == 'pending'
        && (!('inventoryCommitStatus' in data)
            || data.inventoryCommitStatus == 'none')
        && data.items is list
        && data.items.size() > 0;
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isActiveAdmin();
    }

    match /categories/{categoryId} {
      allow read: if resource.data.active == true || isActiveAdmin();
      allow create, update, delete: if isActiveAdmin();
    }

    match /products/{productId} {
      allow read: if resource.data.active == true || isActiveAdmin();
      allow create, update, delete: if isActiveAdmin();
    }

    match /inventory/{productId} {
      allow read: if true;
      allow write: if isActiveAdmin();
    }

    match /customers/{customerId} {
      allow read: if isOwner(customerId) || isActiveAdmin();

      allow create: if isOwner(customerId)
        && request.resource.data.role == 'customer'
        && request.resource.data.status == 'active';

      // Owners may update profile fields but never escalate role/status/email.
      allow update: if isActiveAdmin()
        || (isOwner(customerId)
            && request.resource.data.role == resource.data.role
            && request.resource.data.status == resource.data.status
            && request.resource.data.email == resource.data.email);

      allow delete: if false;
    }

    match /orders/{orderId} {
      allow read: if isActiveAdmin()
        || (isSignedIn()
            && 'customerId' in resource.data
            && resource.data.customerId == request.auth.uid);

      allow create: if orderCreateValid()
        && (
          !('customerId' in request.resource.data)
          || (isSignedIn()
              && request.resource.data.customerId == request.auth.uid)
        );

      allow update, delete: if isActiveAdmin();
    }
  }
}
