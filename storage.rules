rules_version = '2';

/**
 * SeriousFlux Storage Security Rules (GAP-001 / ADR-024).
 *
 * Media lives under `media/{folder}/{file}` (see MediaService).
 * Public read; privileged writes go through Firebase Admin SDK
 * (`uploadMediaAction`) so uploads do not depend on Storageâ†”Firestore
 * cross-service IAM (`firestore.get` in Storage rules).
 */
service firebase.storage {
  match /b/{bucket}/o {
    match /media/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
