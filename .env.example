# Firebase web client (required)
# Copy to .env.local and fill from Firebase Console → Project settings → Your apps

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Storefront origin (required for Mercado Pago back_urls + notification_url)
# Production: public HTTPS origin with NO trailing slash (e.g. https://shop.example.com)
# Local: http://localhost:3000 — preferences work, but webhooks will NOT auto-mark orders paid
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Payment providers — credentials are server-side only (RFC-016.5)
# Never put access tokens / secret keys / webhook secrets in Firestore.
# Enable/disable providers via StoreSettings.paymentProviders (public config).
# Full guide: docs/payments-mercadopago.md
# -----------------------------------------------------------------------------

# Mercado Pago (Checkout Pro + webhooks)
# Panel: https://www.mercadopago.com/developers/panel/app
#
# Mandatory for live checkout + automatic paid sync:
#   MERCADOPAGO_ACCESS_TOKEN
#   MERCADOPAGO_WEBHOOK_SECRET
#   NEXT_PUBLIC_APP_URL (public HTTPS — see above)
#
# Recommended (optional — reserved for future client SDK / Bricks):
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
# true = sandbox_init_point (default); false = production init_point
MERCADOPAGO_SANDBOX=true

# Stripe (reserved — implement StripeProvider before enabling in Store Settings)
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=

# PayPal (reserved — implement PayPalProvider before enabling in Store Settings)
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_WEBHOOK_ID=
# PAYPAL_MODE=sandbox

# Bank Transfer (reserved — typically no API secrets; public instructions may live
# in StoreSettings.paymentProviders.bankTransfer.description or a future field)
# BANK_TRANSFER_ACCOUNT_HOLDER=
# BANK_TRANSFER_IBAN=
# BANK_TRANSFER_REFERENCE_PREFIX=

# -----------------------------------------------------------------------------
# Notifications — credentials are server-side only (RFC-019 / RFC-019.1)
# Never put API keys in Firestore.
# Admin configures only sender name/email + enable toggles (not providers).
# Dispatch: secret-gated POST /api/notifications/dispatch (GAP-003); UI uses server action
# -----------------------------------------------------------------------------

########################################
# Resend (supported)
# Dashboard: https://resend.com/api-keys
# Verify your sender domain / address before enabling emails in Admin.
########################################
RESEND_API_KEY=

########################################
# Dispatch API hardening (GAP-003 / ADR-019)
# Required for POST /api/notifications/dispatch (server-to-server only).
# Browser UI uses a Firebase-authorized server action — not this secret.
# Generate a long random string (e.g. openssl rand -hex 32).
########################################
NOTIFICATIONS_DISPATCH_SECRET=

########################################
# Reserved for future providers (not supported in Admin UI)
########################################
# SENDGRID_API_KEY=
# MAILGUN_API_KEY=
# AWS_SES_ACCESS_KEY=
# AWS_SES_SECRET_KEY=
# POSTMARK_TOKEN=
